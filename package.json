{
  "name": "intentproof-spec",
  "version": "2.0.1",
  "intentproofSpecVersion": "spec-v2.0.1",
  "private": true,
  "description": "Canonical IntentProof execution specification, schemas, golden oracles, and conformance tests for all SDKs.",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "IntentProof",
    "intentproof",
    "json-schema",
    "observability",
    "conformance",
    "execution-events"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/IntentProof/intentproof-spec.git"
  },
  "bugs": {
    "url": "https://github.com/IntentProof/intentproof-spec/issues"
  },
  "homepage": "https://github.com/IntentProof/intentproof-spec#readme",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "conformance": "bash scripts/run-conformance.sh",
    "check:spec-version": "tsx tools/check-spec-version.ts",
    "spec:integrity:generate": "tsx tools/spec-integrity.ts generate",
    "spec:integrity:sign": "tsx tools/spec-integrity.ts sign",
    "spec:integrity:verify": "tsx tools/spec-integrity.ts verify",
    "spec:compat:classify": "tsx tools/schema-compatibility-classify.ts",
    "spec:fingerprint": "tsx tools/spec-fingerprint.ts",
    "replay:compare": "tsx tools/replay/compare-streams.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:event": "tsx tools/validate-event.ts",
    "normalize:event": "tsx tools/normalize-event.ts",
    "diff:events": "tsx tools/diff-events.ts",
    "ci:local": "npm run spec:integrity:verify && npm run typecheck && npm run test",
    "conformance:certificate": "tsx tools/conformance-certificate.ts",
    "validate:conformance-certificate": "tsx tools/validate-conformance-certificate.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
