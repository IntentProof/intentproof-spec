{
  "schema": "intentproof.policy.v1",
  "policy_id": "reference.payments.refund-with-notification.v1",
  "policy_version": 1,
  "tenant_id": "reference",
  "provenance_class": "platform_attested",
  "name": "Refund with notification",
  "description": "Requires successful refund execution, ledger recording, and customer notification events.",
  "spec_version": "1.0.0",
  "scope": {
    "any_event_action_in": [
      "payments.refund.execute",
      "ledger.refund.record",
      "customer.notify.refund"
    ],
    "ignore_flows_with_no_match": false
  },
  "instrumentation_requirement": "operational",
  "rules": [
    {
      "id": "required-refund-executed",
      "category": "required",
      "severity": "high",
      "spec": {
        "action": "payments.refund.execute",
        "min": 1,
        "where": {
          "status": "ok"
        }
      }
    },
    {
      "id": "required-ledger-recorded",
      "category": "required",
      "severity": "high",
      "spec": {
        "action": "ledger.refund.record",
        "min": 1,
        "where": {
          "status": "ok"
        }
      }
    },
    {
      "id": "required-customer-notified",
      "category": "required",
      "severity": "high",
      "spec": {
        "action": "customer.notify.refund",
        "min": 1,
        "where": {
          "status": "ok"
        }
      }
    }
  ],
  "policy_fingerprint": "sha256:b200fcfecaf9fcd4bb14c2fbeb92955bf397b1769554aba6b1b8a43e3abddda6",
  "signed_at": "2026-05-16T00:00:00.000Z",
  "signature": {
    "alg": "none",
    "key_id": "reference-payments",
    "value": ""
  }
}
