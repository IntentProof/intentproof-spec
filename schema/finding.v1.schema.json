{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentproof.dev/schema/finding.v1.schema.json",
  "title": "Finding",
  "type": "object",
  "properties": {
    "rule_id": { "type": "string" },
    "rule_category": {
      "type": "string",
      "enum": [
        "required",
        "forbidden",
        "ordering",
        "cardinality",
        "temporal",
        "consensus",
        "value_bound",
        "claim_match"
      ]
    },
    "outcome": { "type": "string", "enum": ["pass", "fail", "inconclusive"] },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
    "reason": {
      "type": "string",
      "enum": [
        "fail.cardinality.not_exact",
        "fail.cardinality.out_of_range",
        "fail.cardinality.over_max",
        "fail.cardinality.under_min",
        "fail.claim_match.mismatch",
        "fail.consensus.disagreement",
        "fail.consensus.insufficient",
        "fail.consensus.threshold_unmet",
        "fail.forbidden.after_predecessor",
        "fail.forbidden.present",
        "fail.forbidden.without_predecessor",
        "fail.ordering.out_of_order",
        "fail.ordering.unmatched_pair",
        "fail.ordering.violated",
        "fail.required.missing",
        "fail.required.over_max",
        "fail.required.under_min",
        "fail.temporal.below_min",
        "fail.temporal.exceeded_max",
        "fail.temporal.negative_interval",
        "fail.temporal.window_violated",
        "fail.value_bound.out_of_range",
        "inconclusive.claim_match.claim_missing",
        "inconclusive.claim_match.expected_missing",
        "inconclusive.claim_match.source_unsigned",
        "inconclusive.claim_match.unsupported_rule_category",
        "inconclusive.consensus.claim_missing",
        "inconclusive.consensus.external_unavailable",
        "inconclusive.consensus.source_stale",
        "inconclusive.ordering.after_missing",
        "inconclusive.ordering.before_missing",
        "inconclusive.required.unsupported_rule_category",
        "inconclusive.temporal.clock_skew_within_tolerance",
        "inconclusive.temporal.duration_invalid",
        "inconclusive.temporal.missing_anchor",
        "inconclusive.unknown.unsupported_rule_category",
        "inconclusive.value_bound.bound_invalid",
        "inconclusive.value_bound.claim_missing",
        "inconclusive.value_bound.operator_unsupported",
        "inconclusive.value_bound.unsupported_rule_category",
        "pass.cardinality.satisfied",
        "pass.claim_match.matched",
        "pass.consensus.threshold_met",
        "pass.forbidden.absent",
        "pass.ordering.satisfied",
        "pass.required.satisfied",
        "pass.temporal.within_window",
        "pass.value_bound.satisfied"
      ]
    },
    "evidence_event_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_attestation_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "remediation_hint": { "type": "string" },
    "human_summary": { "type": "string" }
  },
  "required": [
    "rule_id", "rule_category", "outcome", "severity", "reason", "evidence_event_ids"
  ],
  "additionalProperties": false
}
