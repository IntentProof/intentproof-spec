{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentproof.dev/schema/conformance_certificate.v1.schema.json",
  "$comment": "Normative IntentProof source tree: https://github.com/IntentProof/intentproof-spec/tree/main/schema — $id is a logical URI; see README.",
  "title": "IntentProof Conformance Certificate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "certificateVersion",
    "issuer",
    "issuedAt",
    "subject",
    "spec",
    "conformanceReportDigest",
    "claims"
  ],
  "properties": {
    "certificateVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Certificate schema / artifact family version (e.g. cert-v0.1.0 or SemVer aligned with spec releases)."
    },
    "issuer": {
      "type": "string",
      "minLength": 1,
      "description": "Opaque issuer identifier (e.g. intentproof-ci); may later be a DID or key id."
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "language", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      },
      "description": "SDK identity; SHOULD mirror conformance-report subject/sdk."
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specVersion", "specFingerprint"],
      "properties": {
        "specVersion": { "type": "string", "minLength": 1 },
        "specFingerprint": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "specCommit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$",
          "description": "Optional pinned spec repository git commit (lowercase hex)."
        }
      }
    },
    "conformanceReportDigest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 over canonical bytes of the source conformance-report.json (or agreed canonicalization)."
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oracle", "allPhasesPass"],
      "properties": {
        "oracle": {
          "type": "string",
          "minLength": 1,
          "description": "Oracle identifier (e.g. intentproof-spec/run-conformance)."
        },
        "allPhasesPass": { "type": "boolean" }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "value"],
      "properties": {
        "alg": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      },
      "description": "Optional attestation signature; required for Stage 2 exit per certificate-issuance-policy.md."
    }
  }
}
