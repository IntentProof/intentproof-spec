{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentproof.dev/schema/bundle-manifest.v1.schema.json",
  "title": "BundleManifest",
  "type": "object",
  "properties": {
    "schema": { "type": "string", "const": "intentproof.bundle.manifest.v1" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "flow_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "event_merkle_root": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "attestation_merkle_root": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "verification_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec_version",
        "verifier_version",
        "policy_versions",
        "export_profile",
        "flow_snapshot_id",
        "run_id"
      ],
      "properties": {
        "spec_version": { "type": "string", "minLength": 1 },
        "verifier_version": { "type": "string", "minLength": 1 },
        "policy_versions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "export_profile": {
          "type": "string",
          "enum": ["full", "auditor", "minimal-claim", "counterparty"]
        },
        "flow_snapshot_id": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 }
      }
    },
    "signature": {
      "type": "object",
      "properties": {
        "alg": { "type": "string" },
        "key_id": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["alg", "key_id", "value"],
      "additionalProperties": false
    }
  },
  "required": [
    "schema",
    "bundle_id",
    "created_at",
    "flow_id",
    "tenant_id",
    "files",
    "verification_profile"
  ],
  "additionalProperties": false
}
